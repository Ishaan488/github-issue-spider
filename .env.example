# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key for the background worker to bypass RLS (Required for worker)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Encryption Key for securing user GitHub Tokens (Required)
# Must be a 32-character string. You can generate one using: openssl rand -hex 16
ENCRYPTION_KEY=your_32_character_encryption_key_here